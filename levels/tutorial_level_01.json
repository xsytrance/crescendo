{
  "level_id": "tutorial_01",
  "name": "First Resonance",
  "mode": "Standard",
  "description": "A deterministic onboarding board that teaches matching, multiplier flow, resonance gain/loss, crescendo charging/activation, stock draw, and first motif pickup.",
  "version": "v1",
  "board": {
    "rows": 4,
    "cols": 4,
    "cards": [
      { "slot": [1, 1], "card_id": "A1", "pair_key": "A", "face_state": "down" },
      { "slot": [1, 2], "card_id": "B1", "pair_key": "B", "face_state": "down" },
      { "slot": [1, 3], "card_id": "C1", "pair_key": "C", "face_state": "down" },
      { "slot": [1, 4], "card_id": "D1", "pair_key": "D", "face_state": "down" },

      { "slot": [2, 1], "card_id": "B2", "pair_key": "B", "face_state": "down" },
      { "slot": [2, 2], "card_id": "A2", "pair_key": "A", "face_state": "down" },
      { "slot": [2, 3], "card_id": "D2", "pair_key": "D", "face_state": "down" },
      { "slot": [2, 4], "card_id": "C2", "pair_key": "C", "face_state": "down" },

      { "slot": [3, 1], "card_id": "E1", "pair_key": "E", "face_state": "down" },
      { "slot": [3, 2], "card_id": "F1", "pair_key": "F", "face_state": "down" },
      { "slot": [3, 3], "card_id": "G1", "pair_key": "G", "face_state": "down" },
      { "slot": [3, 4], "card_id": "H1", "pair_key": "H", "face_state": "down" },

      { "slot": [4, 1], "card_id": "F2", "pair_key": "F", "face_state": "down" },
      { "slot": [4, 2], "card_id": "E2", "pair_key": "E", "face_state": "down" },
      { "slot": [4, 3], "card_id": "H2", "pair_key": "H", "face_state": "down" },
      { "slot": [4, 4], "card_id": "G2", "pair_key": "G", "face_state": "down" }
    ]
  },
  "initial_state": {
    "turn_index": 1,
    "score": 0,
    "multiplier": 1,
    "resonance": 0,
    "resonance_cap": 100,
    "crescendo_threshold": 100,
    "crescendo_charges": 0,
    "max_crescendo_charges": 3,
    "stock_count": 1,
    "max_stock_count": 1,
    "endless_mode_enabled": false,
    "motif_slots": 6,
    "active_motifs": []
  },
  "tutorial_overrides": {
    "grant_motif_choice_on_turn": 7,
    "motif_offer": ["M001", "M003", "M004"],
    "default_motif_pick": "M001",
    "enable_tooltip_ping_on_turn": 8
  },
  "scoring_profile": {
    "base_points_per_match": 100,
    "chain_bonus_points": 20,
    "use_core_step_multiplier": true
  },
  "scripted_turns": [
    {
      "turn": 1,
      "required_action": "move",
      "input": [[1, 1], [2, 2]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "multiplier_end": 2,
        "score_end": 100
      },
      "coachmark": "Match identical cards to score. Nice start—your multiplier is now 2x next turn."
    },
    {
      "turn": 2,
      "required_action": "move",
      "input": [[1, 2], [2, 1]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "resonance_end": 40,
        "multiplier_end": 3,
        "score_end": 300
      },
      "coachmark": "Consecutive matches raise multiplier and build resonance."
    },
    {
      "turn": 3,
      "required_action": "move",
      "input": [[1, 3], [1, 4]],
      "expected": {
        "match_count": 0,
        "base_points_gained": 0,
        "resonance_delta": -15,
        "resonance_end": 25,
        "multiplier_end": 2,
        "score_end": 300
      },
      "coachmark": "A miss costs resonance and drops multiplier by 1."
    },
    {
      "turn": 4,
      "required_action": "move",
      "input": [[1, 4], [2, 3]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "resonance_end": 45,
        "multiplier_end": 3,
        "score_end": 500
      },
      "coachmark": "Recovered. Keep matching to fill resonance toward Crescendo."
    },
    {
      "turn": 5,
      "required_action": "move",
      "input": [[1, 3], [2, 4]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "resonance_end": 65,
        "multiplier_end": 4,
        "score_end": 800
      },
      "coachmark": "You now know both C and D pairs—information from misses still matters."
    },
    {
      "turn": 6,
      "required_action": "move",
      "input": [[3, 1], [4, 2]],
      "expected": {
        "match_count": 2,
        "base_points_gained": 220,
        "resonance_delta": 50,
        "resonance_end": 15,
        "crescendo_charges_end": 1,
        "multiplier_end": 5,
        "score_end": 1680
      },
      "coachmark": "Big turn! Crossing 100 resonance converts into 1 Crescendo charge."
    },
    {
      "turn": 7,
      "required_action": "activate_crescendo",
      "input": [[3, 2], [4, 1]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 130,
        "resonance_delta": 20,
        "resonance_end": 35,
        "crescendo_charges_end": 0,
        "multiplier_end": 6,
        "score_end": 2330
      },
      "coachmark": "Crescendo is player-activated and consumes one stored charge on use."
    },
    {
      "turn": 8,
      "required_action": "move",
      "input": [[3, 3], [3, 4]],
      "expected": {
        "match_count": 0,
        "base_points_gained": 0,
        "resonance_delta": -15,
        "resonance_end": 20,
        "multiplier_end": 5,
        "score_end": 2330
      },
      "coachmark": "If you get stuck later, stock draw is legal only in deadlock."
    },
    {
      "turn": 9,
      "required_action": "move",
      "input": [[3, 4], [4, 3]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "resonance_end": 40,
        "multiplier_end": 6,
        "score_end": 2830
      },
      "coachmark": "Tooltip hint unlocked: hover/tap HUD icons for mechanic definitions."
    },
    {
      "turn": 10,
      "required_action": "move",
      "input": [[3, 3], [4, 4]],
      "expected": {
        "match_count": 1,
        "base_points_gained": 100,
        "resonance_delta": 20,
        "resonance_end": 60,
        "multiplier_end": 7,
        "score_end": 3430,
        "board_clear": true,
        "run_result": "run_success"
      },
      "coachmark": "Board clear! You completed the tutorial objective."
    }
  ],
  "success_criteria": {
    "board_clear_required": true,
    "max_turns": 14,
    "minimum_score": 2000
  },
  "failure_criteria": {
    "deadlock_with_no_stock": true,
    "exceed_max_turns": true
  }
}
